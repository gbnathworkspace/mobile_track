<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MobileTrack" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="Theme.MobileTrack.Overlay" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowDisablePreview">false</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
